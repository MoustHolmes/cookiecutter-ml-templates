[build-system]
{%- if deps_manager in ['uv', 'pixi'] %}
requires = ["hatchling"]
build-backend = "hatchling.build"
{%- else %}
requires = ["setuptools"]
build-backend = "setuptools.build_meta"
{%- endif %}
{% if deps_manager in ['uv', 'pixi'] %}
[tool.hatch.build.targets.wheel]
packages = ["src/{{repo_name}}"]
{% endif %}
[project]
name = "{{repo_name}}"
version = "0.0.1"
description = "{{description}}"
authors = [
  { name = "{{author_name}}", email = "{{author_email}}" },
]
{% if open_source_license != 'No license file' %}license = { file = "LICENSE" }{% endif %}
keywords = ["machine learning", "MLOps"]
classifiers = [
  "Development Status :: 3 - Alpha",
  "Programming Language :: Python :: 3",
]
readme = "README.md"
requires-python = ">={{python_version}}"

{%- if deps_manager == 'uv' %}
dependencies = [
    "torch>=2.0.0",
    "lightning>=2.0.0",
    "hydra-core>=1.3.0",
    "wandb>=0.15.0",
    "torchvision>=0.15.0",
    "numpy>=1.24.0",
    "omegaconf>=2.3.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.4.0",
    "pytest-cov>=4.1.0",
    "ruff>=0.1.0",
    "mypy>=1.5.0",
    "pre-commit>=3.4.0",
    "mkdocs>=1.5.0",
    "mkdocs-material>=9.4.0",
    "invoke>=2.2.0",
]
{%- elif deps_manager == 'pixi' %}
# Dependencies managed by pixi (see pixi.toml)
{%- else %}
dynamic = ["dependencies", "optional-dependencies"]

[tool.setuptools.dynamic]
dependencies = {file = ["requirements.txt"]}

[tool.setuptools.dynamic.optional-dependencies]
dev = {file = ['requirements_dev.txt']}
{%- endif %}

[tool.ruff]
line-length = 120

[tool.ruff.lint]
select = ["I", "N", "E", "W", ]

[tool.coverage.run]
omit = ["tests/*"]

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
addopts = [
    "--strict-markers",
    "--doctest-modules",
    "--color=yes",
    "--import-mode=importlib",
]
filterwarnings = [
    "ignore::DeprecationWarning",
    "ignore::UserWarning",
]
