[workspace]
name = "{{repo_name}}"
version = "0.0.1"
description = "{{description}}"
channels = ["conda-forge"]
platforms = ["linux-64", "osx-64", "osx-arm64", "win-64"]
requires-pixi = ">=0.40"

[dependencies]
python = "{{python_version}}.*"
lightning = ">=2.0.0"
hydra-core = ">=1.3.0"
wandb = ">=0.15.0"
numpy = ">=1.24.0"
omegaconf = ">=2.3.0"

[pypi-dependencies]
{{repo_name}} = { path = ".", editable = true }

[feature.cpu.dependencies]
pytorch = ">=2.0.0"
torchvision = ">=0.15.0"

[feature.cuda.dependencies]
pytorch-gpu = ">=2.0.0"
torchvision = ">=0.15.0"

[feature.cuda.system-requirements]
cuda = "12"

[feature.cuda.activation]
env.TRITON_PTXAS_PATH = "$CONDA_PREFIX/bin/ptxas"

[feature.dev.dependencies]
pytest = ">=7.4.0"
pytest-cov = ">=4.1.0"
ruff = ">=0.1.0"
mypy = ">=1.5.0"
pre-commit = ">=3.4.0"
ipykernel = "*"
mkdocs-material = ">=9.4.0"
mkdocstrings = ">=0.24.0"

[environments]
default = { features = ["cpu", "dev"] }
cuda = { features = ["cuda", "dev"] }

[tasks]
train = "python src/{{repo_name}}/train.py"
test = "pytest tests/"
lint = "ruff check ."
format = "ruff format ."
preprocess = "python src/{{repo_name}}/data/make_dataset.py"
{%- if project_structure == 'full' %}
build-docs = "mkdocs build --strict"
serve-docs = "mkdocs serve"
{%- endif %}
