_target_: {{repo_name}}.flow_matching_module.LatentFlowMatchingCFG

model:
  _target_: {{repo_name}}.models.mlp.MoonsNet
  input_dim: 196 # 4 * 7 * 7
  output_dim: 196
  hidden_dim: 512
  time_dim: 64
  # 10 digits + 1 null token
  num_classes: 11

latent_processor:
  _target_: {{repo_name}}.modules.latent_processors.AutoencoderWrapper
  autoencoder:
    _target_: {{repo_name}}.vae_module.SpatialVAE
    in_channels: 1
    latent_channels: 4
    kl_weight: 0.00025
    lr: 0.001
  checkpoint_path: ""

alpha_beta_scheduler:
  _target_: {{repo_name}}.modules.schedulers.LinearScheduler
  data_dim: 4 # Rank of the data tensor (B, C, H, W) -> Rank 4

sampler:
  _target_: {{repo_name}}.modules.samplers.GaussianSampler
  target_shape: [4, 7, 7]

ode_solver:
  _target_: {{repo_name}}.modules.solvers.EulerSolver

num_classes: 10
cfg_prob: 0.1
guidance_scale: 3.0

optimizer:
  _target_: torch.optim.Adam
  _partial_: true
  lr: 0.0001
