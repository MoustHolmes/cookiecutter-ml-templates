def test_datamodule_attributes():
    """Custom DataModule has the expected interface."""
    dm = DataModule(batch_size=32, num_workers=0)
    assert dm.hparams.batch_size == 32
    assert dm.hparams.num_workers == 0
    assert hasattr(dm, "prepare_data")
