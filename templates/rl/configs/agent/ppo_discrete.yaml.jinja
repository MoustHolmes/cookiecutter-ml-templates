_target_: {{repo_name}}.ppo_module.PPOModule

# Actor MLP — input_dim / output_dim injected by the env config
actor:
  _target_: {{repo_name}}.models.MLP
  input_dim: ???
  output_dim: ???         # n_actions (logits)
  hidden_dim: 64
  num_layers: 2
  activation: tanh
  orthogonal_init: true
  output_std: 0.01

# Critic MLP — input_dim injected by the env config
critic:
  _target_: {{repo_name}}.models.MLP
  input_dim: ???
  output_dim: 1
  hidden_dim: 64
  num_layers: 2
  activation: tanh
  orthogonal_init: true
  output_std: 1.0

discrete: true

# Rollout collection
num_steps: 128
num_envs: 4             # must match RolloutDataModule.num_envs

# PPO hyperparameters
gamma: 0.99
gae_lambda: 0.95
num_minibatches: 4
update_epochs: 4
clip_coef: 0.2
ent_coef: 0.01
vf_coef: 0.5
max_grad_norm: 0.5
norm_adv: true
clip_vloss: true
target_kl: null

# LR annealing
anneal_lr: true
total_timesteps: 500000

optimizer:
  _target_: torch.optim.Adam
  _partial_: true
  lr: 2.5e-4
  eps: 1.0e-5
