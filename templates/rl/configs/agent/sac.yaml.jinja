_target_: {{repo_name}}.sac_module.SACModule

# Actor network — obs_dim / action_dim injected by the env config
actor:
  _target_: {{repo_name}}.models.actor.StochasticActor
  obs_dim: ???
  action_dim: ???
  hidden_dim: 256
  num_layers: 2

# Critic network
critic:
  _target_: {{repo_name}}.models.critic.TwinCritic
  obs_dim: ???
  action_dim: ???
  hidden_dim: 256
  num_layers: 2

# Action space scaling — injected by the env config
action_scale: ???       # (high - low) / 2
action_bias: ???        # (high + low) / 2

# Action sampling bounds
log_std_min: -5
log_std_max: 2

# SAC hyperparameters
gamma: 0.99
tau: 0.005
batch_size: 256
learning_starts: 1000
collect_steps_per_update: 1
gradient_steps: 1

# Temperature / entropy auto-tuning
init_alpha: 1.0
target_entropy: null    # null → auto-set to -action_dim at training start

# Optimizers
actor_optimizer:
  _target_: torch.optim.Adam
  _partial_: true
  lr: 3.0e-4

critic_optimizer:
  _target_: torch.optim.Adam
  _partial_: true
  lr: 3.0e-4

alpha_optimizer:
  _target_: torch.optim.Adam
  _partial_: true
  lr: 3.0e-4
