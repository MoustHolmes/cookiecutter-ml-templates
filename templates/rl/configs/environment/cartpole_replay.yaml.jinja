# @package _global_

# RLDataModule wrapping CartPole-v1 — for DQN
# CartPole-v1: obs_dim=4 (pos, vel, angle, ang_vel), n_actions=2 (left/right)
env:
  _target_: {{repo_name}}.data.env_datamodule.RLDataModule
  env_id: "CartPole-v1"
  buffer_size: 10000
  batch_size: 128
  num_workers: 0
  seed: 42
  normalize_obs: false    # CartPole obs are already bounded
  reward_scale: 1.0
  num_batches_per_epoch: 100  # steps per Lightning epoch

# Inject environment dimensions into agent sub-configs
agent:
  q_network:
    input_dim: 4
    output_dim: 2
